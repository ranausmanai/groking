{
  "name": "groking-cli",
  "version": "0.1.7",
  "description": "Terminal coding agent for Grok via xAI Responses API",
  "license": "MIT",
  "author": "Usman",
  "homepage": "https://github.com/ranausmanai/groking#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ranausmanai/groking.git"
  },
  "bugs": {
    "url": "https://github.com/ranausmanai/groking/issues"
  },
  "keywords": [
    "grok",
    "xai",
    "cli",
    "coding-agent",
    "ai",
    "terminal",
    "refactor"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "bin": {
    "groking": "dist/cli.js",
    "grokcode": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "prepack": "npm run build",
    "start": "node dist/cli.js",
    "serve": "http-server -p 8080",
    "test": "node --import tsx --test test/**/*.test.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "dotenv": "^17.2.3",
    "openai": "^6.6.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@types/node": "^22.18.0",
    "http-server": "^14.1.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  },
  "main": "dist/cli.js",
  "directories": {
    "doc": "docs",
    "test": "test"
  }
}
